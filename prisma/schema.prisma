// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Hero {
  id String @id @default(cuid())

  name    String      @unique
  role    HeroRole
  element HeroElement
  rarity  HeroRarity

  owners UserHeroCollection[]

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("heroes")
}

model User {
  id        String @id @default(uuid()) @db.Uuid
  discordId String @unique

  level  Int @default(1)
  xp     Int @default(0)
  nextXp Int
  gold   Int @default(0)

  heroOwned        UserHeroCollection[]
  dailyQuests      DailyQuestProgress[]
  idleQuest        IdleQuest?

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("users")
}

model DailyQuestProgress {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  date   String

  mission1Completed Boolean @default(false)
  mission1Claimed   Boolean @default(false)
  mission2Completed Boolean @default(false)
  mission2Claimed   Boolean @default(false)
  mission3Completed Boolean @default(false)
  mission3Claimed   Boolean @default(false)

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@unique([userId, date])
  @@map("daily_quest_progress")
}

model IdleQuest {
  id     String @id @default(uuid()) @db.Uuid
  userId String @unique @db.Uuid

  startedAt DateTime
  endsAt    DateTime
  claimed   Boolean @default(false)

  User User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("idle_quests")
}

model UserHeroCollection {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid
  heroId String

  level Int @default(1)
  power Int

  User User @relation(fields: [userId], references: [id])
  Hero Hero @relation(fields: [heroId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @default(now()) @updatedAt

  @@map("user_hero_collection")
}

enum HeroRole {
  Healer
  Damage_Dealer
  Guardian
  Support
}

enum HeroElement {
  Water
  Fire
  Wind
  Earth

  Ice
  Inferno
  Cyclone
  Mud

  Frost
  Plasma
  Tempest
  Sand

  Glacier
  Phoenix
  Hurricane
  Rock

  Tsunami
  Supernova
  Whirlwind
  Titan
}

enum HeroRarity {
  Common
  Rare
  Epic
  Legendary
  Mythical
}
